# ============================================================
# Snapmaker U1 connection — set these to your printer's LAN IP/port.
# Find the IP from your router's DHCP leases or Snapmaker's app.
# Default Moonraker port is 7125.
# ============================================================

SNAPMAKER_U1_HOST=192.168.1.100
SNAPMAKER_U1_PORT=7125

# ============================================================
# Optional overrides
# ============================================================

# Path to the connection JSON file. Defaults to <data-dir>/u1_config.json.
# SNAPMAKER_U1_CONFIG=/path/to/u1_config.json

# Where runtime state lives (configs, photos, history, material map).
# Resolution if unset:
#   1. SNAPMAKER_U1_DATA_DIR (this env var)
#   2. /opt/data/snapmaker_u1   (auto-detected if present — Hermes-agent setup)
#   3. ~/.local/share/snapmaker-u1   (community default; follows XDG Base Dir)
# SNAPMAKER_U1_DATA_DIR=/path/to/your/data/dir
