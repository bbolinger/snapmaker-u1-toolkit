# ============================================================
# Snapmaker U1 connection — set these to your printer's LAN IP/port.
# Find the IP from your router's DHCP leases or Snapmaker's app.
# Default Moonraker port is 7125.
#
# LEAVE COMMENTED if you'd rather let the workflow ask on first run —
# it prompts for the address and saves it to u1_config.json. A copied
# example value here is NOT a configured printer: a deliberately saved
# u1_config.json beats .env values (only a real process environment
# variable outranks it).
# ============================================================

#SNAPMAKER_U1_HOST=192.168.1.100
#SNAPMAKER_U1_PORT=7125

# ============================================================
# Optional overrides
# ============================================================

# Path to the connection JSON file. Defaults to <data-dir>/u1_config.json.
# SNAPMAKER_U1_CONFIG=/path/to/u1_config.json

# Where runtime state lives (configs, photos, history, material map).
# Resolution if unset:
#   1. SNAPMAKER_U1_DATA_DIR (this env var)
#   2. /opt/data/snapmaker_u1   (auto-detected if present — Hermes-agent setup)
#   3. ~/.local/share/snapmaker-u1   (community default; follows XDG Base Dir)
# SNAPMAKER_U1_DATA_DIR=/path/to/your/data/dir

# ============================================================
# Pre-start grace period + Telegram cancel (v2.1.0)
# ============================================================

# Shell command the gate runs when the grace window opens (sends the
# operator the cancel warning). Hermes users point it at the bundled script:
# U1_GRACE_NOTIFY_CMD=/opt/data/workspaces/snapmaker-u1-toolkit/tools/u1_grace_notify_hermes.sh

# The notify script calls `hermes send`. The gate spawns it in a stripped
# subprocess env where `hermes` is often NOT on PATH — set the absolute
# binary path or the notify fails (audited pre_start_grace_notify_failed;
# the wait still runs, but you get no Telegram warning).
# HERMES_BIN=/opt/hermes/.venv/bin/hermes

# Window length in seconds (default 120; 0 disables).
# U1_GRACE_PERIOD_SECONDS=120
