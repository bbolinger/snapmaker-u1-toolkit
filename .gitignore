.env
.venv/
.venv_*/
venv/
__pycache__/
*.pyc
.pytest_cache/
artifacts/

# Bootstrap installers that shouldn't be committed (e.g., pip's standalone
# script lands here when someone runs the curl-pipe-python install)
get-pip.py

# Editor / OS noise
*.bak
*.tmp
.DS_Store

# Runtime state — don't commit operator-specific JSON/photos
snapmaker_u1/print_history.json
snapmaker_u1/print_history.jsonl
snapmaker_u1/print_history_state.json
snapmaker_u1/latest_*.jpg
snapmaker_u1/latest_*.json
snapmaker_u1/last_layer/*.jpg
snapmaker_u1/last_layer/*.json
snapmaker_u1/layer_checks/
snapmaker_u1/watchdog/
snapmaker_u1/u1_tool_material_map.json
snapmaker_u1/u1_config.json

# Profile sources fetched/extracted at the user's site — not redistributed
# in the repo. Each user runs the setup scripts to populate these locally.
profiles/snapmaker-stock/
profiles/from-printer/
profiles/user/

# Binary STL fixtures + raw experiment outputs from the v1.6 draft-profile
# empirical validation. Test rig is committed (tests/experiments/), STLs
# are fetched per the rig's download step (3DBenchy from upstream + synth
# locally), and raw timing/categorization data lives outside the repo.
tests/fixtures-v16/
tests/experiments/v16-out/
tests/experiments/v16-results.tsv

# Internal-only design/planning docs — NOT for the public repo (kept locally
# for us). These stay out of public history via the squash-merge to main.
docs/FORM-PROTOCOL.md
docs/v2.1.0-multipart-kits-plan.md
